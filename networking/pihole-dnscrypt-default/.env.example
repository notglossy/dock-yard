# Common settings
TZ=America/Los_Angeles

# Pi-hole web interface password
FTLCONF_webserver_api_password=changeme

# Port for the Pi-hole web UI on the host
PIHOLE_WEB_PORT=80

# Reverse DNS — format: true,<network CIDR>,<router IP>#53,<local domain>
# Example: true,192.168.1.0/24,192.168.1.1#53,home.local
FTLCONF_dns_revServers=

# Temperature unit for the Pi-hole dashboard (f or c)
TEMPERATUREUNIT=f
