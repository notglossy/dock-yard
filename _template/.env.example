# Common settings — these are shared across most stacks.
# Run `id` in your terminal to find your PUID and PGID.
PUID=1000
PGID=1000
TZ=America/New_York

# Paths — adjust to match your host setup.
CONFIG_PATH=/opt/appdata
DATA_PATH=/opt/data

# Service-specific settings
PORT=8080
# Add other service-specific variables below
