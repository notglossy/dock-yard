# PostgreSQL
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme

# Backup retention
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# NFS backup destination — remove driver_opts from the volume if using local storage instead
NFS_HOST=192.168.1.100
NFS_PATH=/path/to/backups
